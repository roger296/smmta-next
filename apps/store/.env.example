# Storefront environment — copy to .env.local for local development.

# Postgres for the storefront's own data (carts, checkouts, mollie_*, outbox).
# Separate database, same instance as smmta_next per docker-compose.yml.
DATABASE_URL=postgresql://smmta:smmta@localhost:5432/smmta_store

# SMMTA-NEXT API surface. The storefront server-to-servers everything via
# this base URL — the customer's browser never talks to the API directly.
SMMTA_API_BASE_URL=http://localhost:8080/api/v1
SMMTA_API_KEY=

# Mollie (wired in Prompt 10). test_xxx in dev/staging, live_xxx in prod.
MOLLIE_API_KEY=
# Public origin Mollie can reach for webhooks. Use ngrok / Cloudflare Tunnel
# in development if needed; it must match a real, reachable URL.
MOLLIE_WEBHOOK_URL_BASE=http://localhost:3000

# SendGrid (wired in Prompt 11).
SENDGRID_API_KEY=
SENDGRID_FROM=orders@filament.shop.cleverdeals.com

# Operator-only admin surface (Prompt 12).
ADMIN_API_KEY=

# Public origin used for canonical URLs / OG images / sitemap entries.
STORE_BASE_URL=http://localhost:3000

NODE_ENV=development
